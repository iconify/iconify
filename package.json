{
	"name": "iconify",
	"private": true,
	"description": "The most versatile icon framework",
	"homepage": "https://iconify.design/",
	"bugs": "https://github.com/iconify/iconify/issues",
	"license": "MIT",
	"author": "Vjacheslav Trushkin <cyberalien@gmail.com> (https://iconify.design)",
	"repository": {
		"type": "git",
		"url": "https://github.com/iconify/iconify.git"
	},
	"scripts": {
		"clean": "rm -rf node_modules */*/node_modules */*/lib */*/dist",
		"fmt": "pnpm recursive --workspace-concurrency=1 --filter \"./(packages|iconify-icon|components|components-css|plugins)/**\" run fmt",
		"lint": "pnpm recursive --workspace-concurrency=1 --filter \"./(packages|iconify-icon|components|components-css|plugins)/**\" run lint",
		"build": "pnpm recursive --workspace-concurrency=1 --filter \"./(packages|iconify-icon|components|components-css|plugins)/**\" run build",
		"test": "pnpm recursive --workspace-concurrency=1 --filter \"./(packages|iconify-icon|components|components-css|plugins)/**\" run test"
	},
	"dependencies": {},
	"devDependencies": {
		"@types/node": "^25.9.4",
		"globals": "^17.7.0",
		"oxlint": "^1.72.0",
		"tsdown": "^0.21.10",
		"typescript": "^5.9.3",
		"vite": "^7.3.6",
		"vitest": "^4.1.9"
	},
	"packageManager": "pnpm@10.34.4",
	"pnpm": {
		"packageExtensions": {
			"tsutils": {
				"peerDependencies": {
					"typescript": "*"
				}
			}
		}
	}
}
