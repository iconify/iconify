{
	"include": ["./src/**/*.ts", "./tests/**/*.ts"],
	"compilerOptions": {
		"target": "ESNext",
		"module": "esnext",
		"declaration": true,
		"declarationMap": false,
		"sourceMap": false,
		"strict": true,
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["node", "vitest/globals"]
	}
}
